# BME Research Accelerator - Environment Configuration
# Copy this file to .env.local and fill in your values

# ===========================================
# API Configuration (Required)
# ===========================================

# Choose your AI provider: openclaw | anthropic | openai | google | deepseek | groq
NEXT_PUBLIC_DEFAULT_PROVIDER=openclaw

# API Key for your chosen provider
# Get your key from: https://platform.openclaw.com (recommended free tier)
NEXT_PUBLIC_API_KEY=your_api_key_here

# Default model (optional, will use provider default if not set)
# OpenClaw: gpt-4o-mini, claude-sonnet-4-20250514, deepseek-chat
# Anthropic: claude-sonnet-4-20250514, claude-opus-4-20250514
# OpenAI: gpt-4o, o3-mini, o4-mini
# Google: gemini-2.5-pro, gemini-2.5-flash
# DeepSeek: deepseek-chat, deepseek-reasoner
# Groq: llama-3.1-70b-versatile, mixtral-8x7b-32768
NEXT_PUBLIC_DEFAULT_MODEL=gpt-4o-mini

# Custom base URL (optional, only needed for custom endpoints)
# NEXT_PUBLIC_BASE_URL=https://your-custom-endpoint.com/v1

# ===========================================
# Feature Flags (Optional)
# ===========================================

# Enable debug mode (shows detailed error messages in development)
NEXT_PUBLIC_DEBUG=false

# Enable analytics (Vercel Analytics)
NEXT_PUBLIC_ANALYTICS_ENABLED=true

# PDF parsing timeout in milliseconds (default: 60000)
PDF_PARSE_TIMEOUT=60000

# DOI resolution timeout in milliseconds (default: 30000)
DOI_RESOLUTION_TIMEOUT=30000

# Chat completion timeout in milliseconds (default: 120000)
CHAT_COMPLETION_TIMEOUT=120000

# ===========================================
# External API Keys (Optional - for enrichment)
# ===========================================

# CrossRef API (free, no key required for basic usage)
# CROSSREF_API_KEY=your_crossref_key

# Semantic Scholar API (free, no key required)
# SEMANTIC_SCHOLAR_API_KEY=your_s2_key

# OpenAlex API (free, no key required)
# OPENALEX_EMAIL=your_email@example.com

# ===========================================
# Application Settings
# ===========================================

# Application URL (used for callbacks and redirects)
# Update this after deploying to Vercel with your custom domain
NEXT_PUBLIC_APP_URL=https://bmeresearch.top

# Maximum file upload size in bytes (default: 52428800 = 50MB)
MAX_UPLOAD_SIZE=5242880

# Enable CORS for specific origins (comma-separated)
CORS_ORIGINS=https://bmeresearch.top,https://www.bmeresearch.top
